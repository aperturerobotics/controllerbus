{
  "name": "@aperturerobotics/controllerbus",
  "description": "Communicating concurrent controllers program framework.",
  "version": "0.53.4",
  "license": "Apache-2.0",
  "author": {
    "name": "Aperture Robotics LLC.",
    "email": "support@aperture.us",
    "url": "http://aperture.us"
  },
  "contributors": [
    {
      "name": "Christian Stewart",
      "email": "christian@aperture.us",
      "url": "http://github.com/paralin"
    }
  ],
  "repository": {
    "url": "git+ssh://git@github.com/aperturerobotics/controllerbus.git"
  },
  "type": "module",
  "scripts": {
    "check": "bun run typecheck && bun run lint",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "deps": "depcheck --ignore-patterns=.eslintrc.cjs,package.json --ignores depcheck,@aptre/common,prettier,rimraf,typescript,@typescript/native-preview",
    "clean": "rimraf ./dist/",
    "build": "tsgo --project tsconfig.json --noEmit false --outDir ./dist/",
    "codegen": "bun run gen",
    "gen": "bun run go:aptre -- generate",
    "gen:force": "bun run go:aptre -- generate --force",
    "format": "bun run format:js && bun run format:go",
    "format:go": "bun run go:aptre -- format",
    "format:js": "prettier --write './!(vendor|dist)/**/(*.ts|*.tsx|*.js|*.html|*.css)'",
    "format:js:all": "prettier --write './!(vendor|dist)/**/(*.ts|*.tsx|*.js|*.html|*.css)'",
    "test": "bun run test:js && bun run test:go",
    "test:js": "bun run typecheck",
    "test:go": "bun run go:aptre -- test",
    "lint": "bun run lint:go && bun run lint:js",
    "lint:go": "bun run go:aptre -- lint",
    "lint:js": "eslint ./",
    "ci": "bun run build && bun run lint:js && bun run lint:go",
    "prepare": "bun run clean && rimraf ./.tools && bun run vendor",
    "vendor": "go mod vendor",
    "go:aptre": "go run -mod=mod github.com/aperturerobotics/common/cmd/aptre",
    "release": "bun run release:version && bun run release:commit",
    "release:minor": "bun run release:version:minor && bun run release:commit",
    "release:version": "bun pm version patch --no-git-tag-version",
    "release:version:minor": "bun pm version minor --no-git-tag-version",
    "release:commit": "git reset && git add package.json && git commit -s -m \"release: v$(bun -p \"require('./package.json').version\")\" && git tag v$(bun -p \"require('./package.json').version\")",
    "release:publish": "git push && git push --tags",
    "precommit": "bun run format"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "devDependencies": {
    "@aptre/common": "0.33.1",
    "@eslint/js": "^10.0.1",
    "@typescript/native-preview": "^7.0.0-dev.20260505.1",
    "depcheck": "^1.4.7",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@aptre/protobuf-es-lite": "1.1.0",
    "starpc": "^0.49.0"
  },
  "resolutions": {
    "@aptre/protobuf-es-lite": "1.1.0"
  },
  "overrides": {
    "@aptre/protobuf-es-lite": "1.1.0"
  }
}
